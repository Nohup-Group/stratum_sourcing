:8080 {
	handle /healthz {
		header Content-Type "application/json"
		header Cache-Control "no-store"
		respond `{"status":"ok"}` 200
	}

	@openclaw_launch {
		path /openclaw /openclaw/
		header_regexp cf_email Cf-Access-Authenticated-User-Email (?i)^[^@]+@nohup\.group$
	}
		handle @openclaw_launch {
			reverse_proxy {$LEXIE_NEW_URL:http://lexie-new.railway.internal:8080} {
				rewrite /api/openclaw/control-ui/launch
				header_up Authorization "Bearer {$OPENCLAW_CONTROL_UI_PROXY_TOKEN}"
				header_up X-OpenClaw-Control-Ui-Auth "{$OPENCLAW_CONTROL_UI_PROXY_TOKEN}"
			header_up X-Forwarded-For "{remote_host}"
			header_up X-Forwarded-Proto "{scheme}"
			header_up X-Forwarded-Host "{host}"
			header_up X-Forwarded-User "{header.Cf-Access-Authenticated-User-Email}"
			header_up X-Agent-User-Email "{header.Cf-Access-Authenticated-User-Email}"
			header_up Cf-Access-Authenticated-User-Email "{header.Cf-Access-Authenticated-User-Email}"
		}
	}

	@openclaw_ui_ws {
		path /openclaw/ui /openclaw/ui/
		header Connection *Upgrade*
		header Upgrade websocket
		header_regexp cf_email Cf-Access-Authenticated-User-Email (?i)^[^@]+@nohup\.group$
	}
		handle @openclaw_ui_ws {
			reverse_proxy {$LEXIE_NEW_URL:http://lexie-new.railway.internal:8080} {
				header_up Authorization "Bearer {$OPENCLAW_CONTROL_UI_PROXY_TOKEN}"
				header_up X-OpenClaw-Control-Ui-Auth "{$OPENCLAW_CONTROL_UI_PROXY_TOKEN}"
			header_up X-Forwarded-For "{remote_host}"
			header_up X-Forwarded-Proto "{scheme}"
			header_up X-Forwarded-Host "{host}"
			header_up X-Forwarded-User "{header.Cf-Access-Authenticated-User-Email}"
			header_up X-Agent-User-Email "{header.Cf-Access-Authenticated-User-Email}"
			header_up Cf-Access-Authenticated-User-Email "{header.Cf-Access-Authenticated-User-Email}"
		}
	}

	@openclaw_ui {
		path /openclaw/ui*
		header_regexp cf_email Cf-Access-Authenticated-User-Email (?i)^[^@]+@nohup\.group$
	}
		handle @openclaw_ui {
			reverse_proxy {$LEXIE_NEW_URL:http://lexie-new.railway.internal:8080} {
				header_up Authorization "Bearer {$OPENCLAW_CONTROL_UI_PROXY_TOKEN}"
				header_up X-OpenClaw-Control-Ui-Auth "{$OPENCLAW_CONTROL_UI_PROXY_TOKEN}"
			header_up X-Forwarded-For "{remote_host}"
			header_up X-Forwarded-Proto "{scheme}"
			header_up X-Forwarded-Host "{host}"
			header_up X-Forwarded-User "{header.Cf-Access-Authenticated-User-Email}"
			header_up X-Agent-User-Email "{header.Cf-Access-Authenticated-User-Email}"
			header_up Cf-Access-Authenticated-User-Email "{header.Cf-Access-Authenticated-User-Email}"
		}
	}

	@openclaw_forbidden path /openclaw /openclaw/ /openclaw/*
	handle @openclaw_forbidden {
		respond "forbidden" 403
	}

	@openclaw_ws {
		path /api/openclaw/ws
		header Connection *Upgrade*
		header Upgrade websocket
		header_regexp cf_email Cf-Access-Authenticated-User-Email (?i)^[^@]+@nohup\.group$
	}
	handle @openclaw_ws {
		rewrite * /
		reverse_proxy {$LEXIE_NEW_URL:http://lexie-new.railway.internal:8080} {
			header_up Authorization "Bearer {$OPENCLAW_CONTROL_UI_PROXY_TOKEN}"
			header_up X-OpenClaw-Control-Ui-Auth "{$OPENCLAW_CONTROL_UI_PROXY_TOKEN}"
			header_up X-Forwarded-For "{remote_host}"
			header_up X-Forwarded-Proto "{scheme}"
			header_up X-Forwarded-Host "{host}"
			header_up X-Forwarded-User "{header.Cf-Access-Authenticated-User-Email}"
			header_up X-Agent-User-Email "{header.Cf-Access-Authenticated-User-Email}"
			header_up Cf-Access-Authenticated-User-Email "{header.Cf-Access-Authenticated-User-Email}"
		}
	}

	@openclaw_ws_public {
		path /api/openclaw/ws
		header Connection *Upgrade*
		header Upgrade websocket
	}
	handle @openclaw_ws_public {
		rewrite * /
		reverse_proxy {$LEXIE_NEW_URL:http://lexie-new.railway.internal:8080}
	}

	@internal_api {
		path /api/*
		header_regexp cf_email Cf-Access-Authenticated-User-Email (?i)^[^@]+@nohup\.group$
	}
	handle @internal_api {
		reverse_proxy {$LEXIE_NEW_URL:http://lexie-new.railway.internal:8080} {
			header_up Authorization "Bearer {$OPENCLAW_CONTROL_UI_PROXY_TOKEN}"
			header_up X-OpenClaw-Control-Ui-Auth "{$OPENCLAW_CONTROL_UI_PROXY_TOKEN}"
			header_up X-Forwarded-For "{remote_host}"
			header_up X-Forwarded-Proto "{scheme}"
			header_up X-Forwarded-Host "{host}"
			header_up X-Forwarded-User "{header.Cf-Access-Authenticated-User-Email}"
			header_up X-Agent-User-Email "{header.Cf-Access-Authenticated-User-Email}"
			header_up Cf-Access-Authenticated-User-Email "{header.Cf-Access-Authenticated-User-Email}"
		}
	}

	handle /api/* {
		reverse_proxy {$LEXIE_NEW_URL:http://lexie-new.railway.internal:8080}
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
