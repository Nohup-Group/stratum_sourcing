:8080 {
	handle /healthz {
		header Content-Type "application/json"
		header Cache-Control "no-store"
		respond `{"status":"ok"}` 200
	}

	@openclaw_launch path /openclaw /openclaw/
	handle @openclaw_launch {
		reverse_proxy {$LEXIE_NEW_URL:http://lexie-new.railway.internal:8080} {
			rewrite /api/openclaw/control-ui/launch
			header_up X-OpenClaw-Control-Ui-Auth "{$OPENCLAW_CONTROL_UI_PROXY_TOKEN}"
			header_up Cf-Access-Jwt-Assertion "{header.Cf-Access-Jwt-Assertion}"
			header_up X-Forwarded-For "{remote_host}"
			header_up X-Forwarded-Proto "{scheme}"
			header_up X-Forwarded-Host "{host}"
			header_up X-Forwarded-User "{header.Cf-Access-Authenticated-User-Email}"
			header_up X-Agent-User-Email "{header.Cf-Access-Authenticated-User-Email}"
			header_up Cf-Access-Authenticated-User-Email "{header.Cf-Access-Authenticated-User-Email}"
		}
	}

	@openclaw_ui_ws {
		path /openclaw/ui /openclaw/ui/
		header Connection *Upgrade*
		header Upgrade websocket
	}
	handle @openclaw_ui_ws {
		reverse_proxy {$LEXIE_NEW_URL:http://lexie-new.railway.internal:8080} {
			header_up X-OpenClaw-Control-Ui-Auth "{$OPENCLAW_CONTROL_UI_PROXY_TOKEN}"
			header_up Cf-Access-Jwt-Assertion "{header.Cf-Access-Jwt-Assertion}"
			header_up X-Forwarded-For "{remote_host}"
			header_up X-Forwarded-Proto "{scheme}"
			header_up X-Forwarded-Host "{host}"
			header_up X-Forwarded-User "{header.Cf-Access-Authenticated-User-Email}"
			header_up X-Agent-User-Email "{header.Cf-Access-Authenticated-User-Email}"
			header_up Cf-Access-Authenticated-User-Email "{header.Cf-Access-Authenticated-User-Email}"
		}
	}

	@openclaw_ui path /openclaw/ui*
	handle @openclaw_ui {
		reverse_proxy {$LEXIE_NEW_URL:http://lexie-new.railway.internal:8080} {
			header_up X-OpenClaw-Control-Ui-Auth "{$OPENCLAW_CONTROL_UI_PROXY_TOKEN}"
			header_up Cf-Access-Jwt-Assertion "{header.Cf-Access-Jwt-Assertion}"
			header_up X-Forwarded-For "{remote_host}"
			header_up X-Forwarded-Proto "{scheme}"
			header_up X-Forwarded-Host "{host}"
			header_up X-Forwarded-User "{header.Cf-Access-Authenticated-User-Email}"
			header_up X-Agent-User-Email "{header.Cf-Access-Authenticated-User-Email}"
			header_up Cf-Access-Authenticated-User-Email "{header.Cf-Access-Authenticated-User-Email}"
		}
	}

	@openclaw_ws {
		path /api/openclaw/ws
		header Connection *Upgrade*
		header Upgrade websocket
	}
	handle @openclaw_ws {
		rewrite * /
		reverse_proxy {$LEXIE_NEW_URL:http://lexie-new.railway.internal:8080} {
			header_up X-OpenClaw-Control-Ui-Auth "{$OPENCLAW_CONTROL_UI_PROXY_TOKEN}"
			header_up Cf-Access-Jwt-Assertion "{header.Cf-Access-Jwt-Assertion}"
			header_up X-Forwarded-For "{remote_host}"
			header_up X-Forwarded-Proto "{scheme}"
			header_up X-Forwarded-Host "{host}"
			header_up X-Forwarded-User "{header.Cf-Access-Authenticated-User-Email}"
			header_up X-Agent-User-Email "{header.Cf-Access-Authenticated-User-Email}"
			header_up Cf-Access-Authenticated-User-Email "{header.Cf-Access-Authenticated-User-Email}"
		}
	}

	handle /api/* {
		reverse_proxy {$LEXIE_NEW_URL:http://lexie-new.railway.internal:8080} {
			header_up X-OpenClaw-Control-Ui-Auth "{$OPENCLAW_CONTROL_UI_PROXY_TOKEN}"
			header_up Cf-Access-Jwt-Assertion "{header.Cf-Access-Jwt-Assertion}"
			header_up X-Forwarded-For "{remote_host}"
			header_up X-Forwarded-Proto "{scheme}"
			header_up X-Forwarded-Host "{host}"
			header_up X-Forwarded-User "{header.Cf-Access-Authenticated-User-Email}"
			header_up X-Agent-User-Email "{header.Cf-Access-Authenticated-User-Email}"
			header_up Cf-Access-Authenticated-User-Email "{header.Cf-Access-Authenticated-User-Email}"
		}
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
