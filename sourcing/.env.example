# Database (Railway provides this automatically)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stratum_sourcing

# Slack integration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_CHANNEL_SOURCING=#sourcing

# Notion integration
NOTION_API_KEY=secret_your-notion-key
NOTION_OCEAN_DATABASE_ID=your-database-id

# LLM provider fallback chain (each tier falls through on failure):
#   1. OpenClaw gateway (production -- WebSocket RPC, handles Codex OAuth internally)
#   2. Codex Responses API (local dev -- direct streaming via OAuth minter)
#   3. Anthropic API (direct, if ANTHROPIC_API_KEY set)
#   4. OpenAI API (direct, if OPENAI_API_KEY set -- last-resort fallback)
OPENCLAW_INTERNAL_PORT=9080
OPENCLAW_GATEWAY_TOKEN=dev-token
OAUTH_MINTER_URL=https://your-minter.up.railway.app
OAUTH_MINTER_KEY=your-minter-key

# ANTHROPIC_API_KEY=sk-ant-your-key
# OPENAI_API_KEY=sk-your-key

LLM_MODEL=gpt-4o

# Cron job authentication
CRON_SECRET=your-cron-secret

# Persistent volume
DATA_DIR=/data

# Scraping settings
FETCH_TIMEOUT_SECONDS=30
FETCH_CONCURRENCY=5
BROWSER_RATE_LIMIT_SECONDS=10
